# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — it never gets committed.

# ----- Database (MongoDB Atlas) -----
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/buddies?retryWrites=true&w=majority"

# ----- Better Auth -----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ----- Google OAuth (Better Auth social provider) -----
# Register an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Provisioned in Day_34; populated by user in .env.local at that time.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Cloudinary (image hosting) -----
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ----- Resend (transactional email) -----
RESEND_API_KEY=""
EMAIL_FROM="Buddies <noreply@example.com>"
